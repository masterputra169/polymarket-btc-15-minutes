# Polymarket CLOB API credentials
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Trading parameters
BANKROLL=100
MAX_DAILY_LOSS_PCT=20
MAX_CONSECUTIVE_LOSSES=5

# Safety
DRY_RUN=true

# Logging
LOG_LEVEL=info

# Poll interval (ms)
POLL_INTERVAL_MS=5000

# Chainlink Data Streams (Option A — exact PTB match with Polymarket resolution source)
# Apply for sponsored API key via Chainlink Labs / Polymarket 15m markets program.
# Without these vars, adapter is dormant and PTB falls back to polymarket_page / chainlink_round.
# CHAINLINK_DS_API_KEY=
# CHAINLINK_DS_USER_SECRET=
# CHAINLINK_DS_BTC_FEED_ID=0x000359843a543ee2fe414dc14c7e7920ef10f4372990b79d6361cdc0dd1ba782
# CHAINLINK_DS_TESTNET=false

# ─── Macro Event Guard ──────────────────────────────────────────────
# Block trading around high-impact macro events (CPI, FOMC, NFP).
# Source: ForexFactory weekly calendar — free, no key needed.
# Ultra-ML (≥95%) overrides the block. Manual events in bot/data/macro_events_manual.json.
MACRO_GUARD_ENABLED=true
MACRO_PRE_MIN=30                    # minutes before event to start blocking
MACRO_POST_MIN=15                   # minutes after event to keep blocking
MACRO_FETCH_INTERVAL_MS=21600000    # 6h — weekly FF calendar, re-fetch periodically
MACRO_IMPACT_LEVELS=High            # comma-separated: High,Medium,Low
MACRO_CURRENCIES=USD                # comma-separated: USD,EUR,GBP

# ─── LLM Regime Classifier (P2 advisory) ────────────────────────────
# Slow-loop (~5min) regime classification via OpenRouter LLM. Shadow mode = log only.
# Requires AI_AGENT_ENABLED=true + OPENROUTER_API_KEY=sk-or-xxx.
# Cost: ~$0.001/call with Gemini Flash × 12/hr = ~$0.30/day.
# Flip LLM_REGIME_SHADOW=false AFTER 2-4 weeks of shadow A/B data confirm alpha.
LLM_REGIME_ENABLED=false
LLM_REGIME_SHADOW=true              # true = log only, false = actively block on conflict
LLM_REGIME_INTERVAL_MS=300000       # 5 min
LLM_REGIME_MAX_TOKENS=500
LLM_REGIME_MIN_CONF=0.70            # ignore classifications below this confidence
LLM_REGIME_ML_BYPASS=0.90           # ML ≥ this overrides LLM block
